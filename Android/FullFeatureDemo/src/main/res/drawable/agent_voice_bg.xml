<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 设置圆角 -->
    <corners android:radius="16dp" />

    <!-- 设置渐变背景 -->
    <gradient
        android:angle="315"
        android:endColor="#87CEEB"
        android:startColor="#8E2DE2"
        android:type="linear" />

    <!-- 可选：设置内边距 -->
    <padding
        android:bottom="10dp"
        android:left="10dp"
        android:right="10dp"
        android:top="10dp" />
</shape>