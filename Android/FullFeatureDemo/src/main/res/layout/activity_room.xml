<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.ding.rtc.demo.RoomActivity">

    <include
        android:id="@+id/room_top_layout"
        layout="@layout/widget_title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <include
        android:id="@+id/room_bottom_layout"
        layout="@layout/widget_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="3dp" />

    <FrameLayout
        android:id="@+id/room_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/room_bottom_layout"
        android:layout_below="@id/room_top_layout"
        android:background="@color/colorF5F7FF">

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/room_view_pager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

        <com.ding.rtc.demo.ui.indicator.CirclePageIndicator
            android:id="@+id/room_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="100dp"
            android:padding="3dp"
            android:visibility="gone"
            app:fillColor="#00acff"
            app:pageColor="#32000000"
            app:strokeWidth="0dp" />

    </FrameLayout>

    <TextView
        android:id="@+id/room_user_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignWithParentIfMissing="true"
        android:layout_above="@id/room_bottom_layout"
        android:layout_marginStart="3dp"
        android:layout_marginBottom="8dp"
        android:text="当前会议人数 1"
        android:textColor="@android:color/holo_red_light" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/group_float_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignBottom="@id/room_view"
        android:layout_alignParentEnd="true"
        android:src="@drawable/audio_group"
        app:fabCustomSize="40dp"
        tools:ignore="ContentDescription,MissingConstraints" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/rtm_chat_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignBottom="@id/room_view"
        android:layout_toLeftOf="@id/group_float_btn"
        android:src="@drawable/rtm_chat"
        app:fabCustomSize="40dp"
        tools:ignore="ContentDescription,MissingConstraints" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/switch_orientation_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignBottom="@id/room_view"
        android:layout_toLeftOf="@id/rtm_chat_btn"
        android:src="@drawable/switch_orientation"
        app:fabCustomSize="40dp"
        tools:ignore="ContentDescription,MissingConstraints" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/subtitle_view"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_above="@id/switch_orientation_btn"
        android:background="#FFF"
        android:visibility="gone">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/subtitle_service_settings"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#FFF"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/subtitle_service_type"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:gravity="center"
                android:text="服务类型"
                android:textColor="@color/black"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/task_id"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:gravity="center"
                android:text="TaskId: "
                android:textColor="@color/black"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/subtitle_service_type" />

            <Spinner
                android:id="@+id/subtitle_service_type_spinner"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:entries="@array/subtitle_service_type_des"
                android:gravity="center"
                android:textColor="@color/black"
                app:layout_constraintLeft_toRightOf="@id/subtitle_service_type"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/subtitle_start_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="20dp"
                android:gravity="center"
                android:text="开启服务"
                android:textColor="@color/black"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/subtitle_service_state"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="字幕服务状态："
            android:textColor="@color/black"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle_service_settings" />

        <TextView
            android:id="@+id/subtitle_speak_language"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="发言语言"
            android:textColor="@color/black"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle_service_state" />

        <Spinner
            android:id="@+id/subtitle_speak_language_spinner"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:textColor="@color/black"
            app:layout_constraintLeft_toRightOf="@id/subtitle_speak_language"
            app:layout_constraintTop_toBottomOf="@+id/subtitle_service_state" />

        <Button
            android:id="@+id/subtitle_translate_language_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="翻译语言"
            android:textColor="@color/black"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle_speak_language" />

        <ListView
            android:id="@+id/subtitle_translate_language_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle_translate_language_btn" />
    </androidx.constraintlayout.widget.ConstraintLayout>


</RelativeLayout>