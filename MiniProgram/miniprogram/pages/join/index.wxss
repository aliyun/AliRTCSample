@import '../../common.wxss';
.join-wrap {
  width: 100%;
  height: 100%;
  position: absolute;
  /* background: linear-gradient(to bottom, #ff6a00, #f59957); */
  color: #5083aa;
  padding-top: 60px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
input {
  margin: 10px 0;
  width: 90%;
  border: 1px solid #eee;
  padding: 0 8px;
  box-sizing: border-box;
  height: 40px;
  line-height: 40px;
  color: white;
}
.select {
  margin: 10px 0;
  width: 90%;
  border: 1px solid #eee;
  padding: 0 8px;
  box-sizing: border-box;
  height: 40px;
  line-height: 40px;
}
.picker {
}
button {
  margin-bottom: 15px;
}
live-pusher,
live-player {
  margin: 10px 0;
  border: 1px solid #ccc;
}
